---
import { defaultLocale, type Locale } from '../../i18n/languages';
import { pageT } from '../../i18n/pages';

const lang = (Astro.currentLocale ?? defaultLocale) as Locale;
const t = pageT('inGedenken', lang);
---
<section class="mx-auto max-w-3xl px-4 py-24 text-center lg:px-6">
  <img src="/images/crest.jpg" alt="" class="mx-auto h-16 w-16 rounded-full object-cover ring-1 ring-line" />
  <h1 class="display mt-8 text-4xl">{t.h1}</h1>
  <p class="mx-auto mt-6 max-w-xl text-base leading-relaxed text-ink-soft">{t.p1}</p>
  <p class="mx-auto mt-4 max-w-xl text-sm text-ink-soft">{t.p2}</p>
</section>
