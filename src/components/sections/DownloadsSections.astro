---
import { defaultLocale, type Locale } from '../../i18n/languages';
import { pageT } from '../../i18n/pages';

const lang = (Astro.currentLocale ?? defaultLocale) as Locale;
const t = pageT('downloads', lang);
---
<section class="mx-auto max-w-6xl px-4 pb-8 pt-16 lg:px-6">
  <h1 class="display text-4xl md:text-5xl">{t.h1}</h1>
  <p class="mt-4 max-w-xl text-base leading-relaxed text-ink-soft">{t.intro}</p>
</section>
<section class="mx-auto max-w-3xl px-4 py-12 lg:px-6">
  <div class="space-y-4">
    {t.files.map((f: any) => (
      <a href="#" class="reveal group flex items-center justify-between gap-4 rounded-2xl border border-line bg-card p-6 transition-colors duration-300 hover:border-club/40">
        <div>
          <p class="font-bold">{f.name}</p>
          <p class="mt-1 text-sm text-ink-soft">{f.desc}</p>
        </div>
        <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-paper text-sm font-semibold transition-all duration-300 group-hover:bg-club group-hover:text-white">PDF</span>
      </a>
    ))}
  </div>
</section>
