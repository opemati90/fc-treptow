---
import { defaultLocale, type Locale } from '../../i18n/languages';
import { pageT } from '../../i18n/pages';

const lang = (Astro.currentLocale ?? defaultLocale) as Locale;
const t = pageT('anmeldung', lang);
---
<section class="mx-auto max-w-6xl px-4 pb-8 pt-16 lg:px-6">
  <h1 class="display text-4xl md:text-5xl">{t.h1}</h1>
  <p class="mt-4 max-w-xl text-base leading-relaxed text-ink-soft">{t.intro}</p>
</section>

<section class="mx-auto max-w-3xl px-4 py-12 lg:px-6">
  <div id="gate" class="rounded-2xl border border-line bg-card p-10 text-center">
    <span class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-club/10 text-xl text-club">🔒</span>
    <h2 class="display mt-5 text-2xl">{t.gateTitle}</h2>
    <p class="mx-auto mt-3 max-w-sm text-sm leading-relaxed text-ink-soft">{t.gateText} <a href="/probetraining" class="font-semibold text-club hover:text-club-deep">{t.gateLink}</a>.</p>
    <form id="gate-form" class="mx-auto mt-6 flex max-w-xs gap-2">
      <label for="code" class="sr-only">{t.codePlaceholder}</label>
      <input id="code" type="text" autocomplete="off" placeholder={t.codePlaceholder} class="w-full rounded-full border border-line bg-paper px-5 py-3 text-center text-sm uppercase tracking-widest outline-none transition-colors focus:border-club" />
      <button type="submit" class="shrink-0 rounded-full bg-club px-5 py-3 text-sm font-semibold text-white transition-colors duration-300 hover:bg-club-deep">{t.gateSubmit}</button>
    </form>
    <p id="gate-error" class="mt-3 hidden text-sm font-medium text-club">{t.gateError}</p>
  </div>

  <form id="reg-form" class="hidden rounded-2xl border border-line bg-card p-8" novalidate>
    <h2 class="display text-2xl">{t.formTitle}</h2>
    <div class="mt-6 grid gap-6 sm:grid-cols-2">
      <div class="flex flex-col gap-2">
        <label for="firstname" class="text-sm font-semibold">{t.firstname}</label>
        <input id="firstname" name="firstname" type="text" required class="rounded-xl border border-line bg-paper px-4 py-3 text-sm outline-none transition-colors focus:border-club" />
      </div>
      <div class="flex flex-col gap-2">
        <label for="lastname" class="text-sm font-semibold">{t.lastname}</label>
        <input id="lastname" name="lastname" type="text" required class="rounded-xl border border-line bg-paper px-4 py-3 text-sm outline-none transition-colors focus:border-club" />
      </div>
      <div class="flex flex-col gap-2">
        <label for="birthdate" class="text-sm font-semibold">{t.birthdate}</label>
        <input id="birthdate" name="birthdate" type="date" required class="rounded-xl border border-line bg-paper px-4 py-3 text-sm outline-none transition-colors focus:border-club" />
      </div>
      <div class="flex flex-col gap-2">
        <label for="reg-email" class="text-sm font-semibold">{t.email}</label>
        <input id="reg-email" name="email" type="email" required class="rounded-xl border border-line bg-paper px-4 py-3 text-sm outline-none transition-colors focus:border-club" />
      </div>
      <div class="flex flex-col gap-2 sm:col-span-2">
        <label for="address" class="text-sm font-semibold">{t.address}</label>
        <input id="address" name="address" type="text" required class="rounded-xl border border-line bg-paper px-4 py-3 text-sm outline-none transition-colors focus:border-club" />
      </div>
      <div class="flex flex-col gap-2">
        <label for="reg-team" class="text-sm font-semibold">{t.team}</label>
        <select id="reg-team" name="team" class="rounded-xl border border-line bg-paper px-4 py-3 text-sm outline-none transition-colors focus:border-club">
          {t.teamOptions.map((o: string) => <option>{o}</option>)}
        </select>
      </div>
      <div class="flex flex-col gap-2">
        <label for="lastclub" class="text-sm font-semibold">{t.lastclub} <span class="font-normal text-ink-soft">{t.optional}</span></label>
        <input id="lastclub" name="lastclub" type="text" class="rounded-xl border border-line bg-paper px-4 py-3 text-sm outline-none transition-colors focus:border-club" />
      </div>
      <div class="flex flex-col gap-2 sm:col-span-2">
        <label for="tariff" class="text-sm font-semibold">{t.tariff}</label>
        <select id="tariff" name="tariff" class="rounded-xl border border-line bg-paper px-4 py-3 text-sm outline-none transition-colors focus:border-club">
          {t.tariffOptions.map((o: string) => <option>{o}</option>)}
        </select>
      </div>
    </div>
    <label class="mt-6 flex items-start gap-3 text-sm text-ink-soft">
      <input type="checkbox" required class="mt-1 h-4 w-4 accent-club" />
      <span>{t.consent} <a href="/datenschutz" class="font-semibold text-club hover:text-club-deep">{t.consentLink}</a> {t.consentRest}</span>
    </label>
    <p
      id="reg-error"
      class="mt-4 hidden text-sm font-medium text-club"
      role="alert"
      data-validation={t.formError}
      data-failure={t.sendFailed}
    >{t.formError}</p>
    <button id="reg-submit" type="submit" data-sending={t.sending} class="group mt-6 inline-flex items-center gap-2 rounded-full bg-club px-6 py-3 text-sm font-semibold text-white transition-all duration-300 ease-(--ease-club) hover:bg-club-deep active:scale-[0.98] disabled:opacity-60">
      {t.submit}
      <span class="flex h-6 w-6 items-center justify-center rounded-full bg-white/15 transition-transform duration-300 ease-(--ease-club) group-hover:translate-x-0.5 rtl:rotate-180">→</span>
    </button>
    <p class="mt-5 text-xs leading-relaxed text-ink-soft">{t.footnote} <a href="/downloads" class="font-semibold text-club hover:text-club-deep">{t.downloadsLabel}</a>.</p>
  </form>

  <div id="reg-success" class="hidden rounded-2xl border border-line bg-card p-10 text-center">
    <span class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-club/10 text-2xl text-club">✓</span>
    <h2 class="display mt-5 text-2xl">{t.successTitle}</h2>
    <p class="mx-auto mt-3 max-w-sm text-sm leading-relaxed text-ink-soft">{t.successText}</p>
  </div>
</section>

<script>
  import { submitForm } from '../../lib/submitForm';

  // Der Code wird vom Trainer nach dem Probetraining vergeben und ist hier bewusst simpel gehalten.
  const UNLOCK_CODE = 'TREPTOW1925';
  const gate = document.getElementById('gate');
  const gateForm = document.getElementById('gate-form') as HTMLFormElement | null;
  const regForm = document.getElementById('reg-form') as HTMLFormElement | null;

  gateForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    const value = (document.getElementById('code') as HTMLInputElement).value.trim().toUpperCase();
    if (value === UNLOCK_CODE) {
      gate?.classList.add('hidden');
      regForm?.classList.remove('hidden');
    } else {
      document.getElementById('gate-error')?.classList.remove('hidden');
    }
  });

  const regErr = document.getElementById('reg-error');
  const regBtn = document.getElementById('reg-submit') as HTMLButtonElement | null;
  const regBtnLabel = regBtn?.textContent?.trim() ?? '';

  regForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!regForm.checkValidity()) {
      regErr!.textContent = regErr!.dataset.validation ?? '';
      regErr?.classList.remove('hidden');
      return;
    }
    regErr?.classList.add('hidden');
    if (regBtn) {
      regBtn.disabled = true;
      regBtn.textContent = regBtn.dataset.sending ?? regBtnLabel;
    }
    try {
      await submitForm(regForm, 'Neue Anmeldung');
      regForm.classList.add('hidden');
      document.getElementById('reg-success')?.classList.remove('hidden');
    } catch {
      regErr!.textContent = regErr!.dataset.failure ?? '';
      regErr?.classList.remove('hidden');
    } finally {
      if (regBtn) {
        regBtn.disabled = false;
        regBtn.textContent = regBtnLabel;
      }
    }
  });
</script>
