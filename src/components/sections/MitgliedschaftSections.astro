---
import { defaultLocale, type Locale } from '../../i18n/languages';
import { pageT } from '../../i18n/pages';

const lang = (Astro.currentLocale ?? defaultLocale) as Locale;
const t = pageT('mitgliedschaft', lang);
const stepLinks = ['/probetraining', undefined, '/anmeldung'];
---
<section class="mx-auto max-w-6xl px-4 pb-8 pt-16 lg:px-6">
  <h1 class="display text-4xl md:text-5xl">{t.h1}</h1>
  <p class="mt-4 max-w-xl text-base leading-relaxed text-ink-soft">{t.intro}</p>
</section>

<section class="mx-auto max-w-6xl px-4 py-12 lg:px-6">
  <div class="grid gap-6 md:grid-cols-3">
    {t.steps.map((s: any, i: number) => (
      <div class="reveal flex flex-col rounded-2xl border border-line bg-card p-7">
        <span class="display text-4xl text-club/25">{i + 1}</span>
        <h2 class="mt-4 text-lg font-bold">{s.title}</h2>
        <p class="mt-2 flex-1 text-sm leading-relaxed text-ink-soft">{s.text}</p>
        {s.linkLabel && <a href={stepLinks[i]} class="mt-5 inline-flex w-max items-center gap-1 text-sm font-semibold text-club hover:text-club-deep">{s.linkLabel} →</a>}
      </div>
    ))}
  </div>
</section>

<section class="mx-auto max-w-6xl px-4 py-12 lg:px-6">
  <div class="grid gap-6 lg:grid-cols-2">
    <div class="reveal rounded-2xl border border-line bg-card p-8">
      <h2 class="display text-2xl">{t.beitraege}</h2>
      <div class="mt-6 space-y-5">
        <div class="flex items-baseline justify-between gap-4 border-b border-line pb-5">
          <div>
            <p class="font-semibold">{t.aktive}</p>
            <p class="mt-1 text-sm text-ink-soft">{t.aktiveDetail}</p>
          </div>
          <p class="display whitespace-nowrap text-3xl">15 €<span class="ml-1 text-sm font-sans font-normal text-ink-soft">{t.proMonat}</span></p>
        </div>
        <div class="flex items-baseline justify-between gap-4">
          <div>
            <p class="font-semibold">{t.ermaessigt}</p>
            <p class="mt-1 text-sm text-ink-soft">{t.ermaessigtDetail}</p>
          </div>
          <p class="display whitespace-nowrap text-3xl">10 €<span class="ml-1 text-sm font-sans font-normal text-ink-soft">{t.proMonat}</span></p>
        </div>
      </div>
    </div>
    <div class="reveal rounded-2xl bg-ink p-8 text-white">
      <h2 class="display text-2xl">{t.bankverbindung}</h2>
      <p class="mt-4 text-sm leading-relaxed text-white/75">{t.bankHint}</p>
      <dl class="mt-6 space-y-4 text-sm">
        <div>
          <dt class="text-white/50">{t.kontoinhaber}</dt>
          <dd class="mt-0.5 font-medium">FC Treptow e. V.</dd>
        </div>
        <div>
          <dt class="text-white/50">{t.iban}</dt>
          <dd class="mt-0.5 font-mono font-medium tracking-wide">DE57 1009 0000 3946 9680 04</dd>
        </div>
      </dl>
      <p class="mt-6 text-sm text-white/75">{t.formsHint} <a href="/downloads" class="font-semibold text-white underline decoration-club decoration-2 underline-offset-4">{t.downloadsLabel}</a>.</p>
    </div>
  </div>
</section>
