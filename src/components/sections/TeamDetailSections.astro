---
import { render, type CollectionEntry } from 'astro:content';
import { defaultLocale, type Locale } from '../../i18n/languages';
import { pageT } from '../../i18n/pages';

interface Props {
  team: CollectionEntry<'teams'>;
}
const { team } = Astro.props;
const { Content } = await render(team);
const d = team.data;
const lang = (Astro.currentLocale ?? defaultLocale) as Locale;
const t = pageT('teamDetail', lang);
---
<!-- Kopfbereich: Das Mannschaftsfoto steht im eigenen Rahmen statt als randloser
     Hintergrund. So wird bei einem 16:9-Mannschaftsfoto niemand angeschnitten, und die
     Überschrift bleibt immer lesbar. imageFocus (im CMS je Foto einstellbar) verschiebt
     den Ausschnitt nur dann, wenn ein Foto ein anderes Seitenverhältnis hat. -->
<section class="bg-ink pb-10 pt-20 sm:pb-12 lg:pb-14 lg:pt-24">
  <div class="mx-auto max-w-6xl px-4 lg:px-6">
    <p class="text-xs font-semibold uppercase tracking-widest text-white/60 sm:text-sm sm:normal-case sm:tracking-normal sm:font-medium">{d.league}</p>
    <h1 class="display mt-2 text-3xl leading-[1.05] text-white sm:text-4xl lg:text-5xl">{d.name}</h1>
    <div class="mt-6 overflow-hidden rounded-2xl bg-white/5 ring-1 ring-white/10 sm:mt-8">
      <img
        src={d.image}
        alt={d.name}
        class="aspect-[16/9] w-full object-cover"
        style={`object-position: 50% ${d.imageFocus}%;`}
        fetchpriority="high"
      />
    </div>
  </div>
</section>

<section class="mx-auto max-w-6xl px-4 py-16 lg:px-6">
  <div class="grid gap-10 lg:grid-cols-5">
    <div class="lg:col-span-2">
      <div class="prose-p:leading-relaxed text-base leading-relaxed text-ink-soft">
        <Content />
      </div>
      <dl class="mt-8 space-y-4">
        <div class="border-b border-line pb-4">
          <dt class="text-xs font-semibold uppercase tracking-widest text-ink-soft">{t.training}</dt>
          <dd class="mt-1 text-sm font-medium">{d.training.join(' ')}</dd>
        </div>
        <div class="border-b border-line pb-4">
          <dt class="text-xs font-semibold uppercase tracking-widest text-ink-soft">{t.platz}</dt>
          <dd class="mt-1 text-sm font-medium">{d.ground}</dd>
        </div>
        <div class="border-b border-line pb-4">
          <dt class="text-xs font-semibold uppercase tracking-widest text-ink-soft">{t.kontakt}</dt>
          <dd class="mt-1 text-sm font-medium"><a href={`mailto:${d.contact}`} class="text-club hover:text-club-deep">{d.contact}</a></dd>
        </div>
      </dl>
      <a href="/mitgliedschaft" class="group mt-8 inline-flex items-center gap-2 rounded-full bg-club px-6 py-3 text-sm font-semibold text-white transition-all duration-300 ease-(--ease-club) hover:bg-club-deep active:scale-[0.98]">
        {t.probetrainingCta}
        <span class="flex h-6 w-6 items-center justify-center rounded-full bg-white/15 transition-transform duration-300 ease-(--ease-club) group-hover:translate-x-0.5 rtl:rotate-180">→</span>
      </a>
    </div>

    <div class="lg:col-span-3">
      <div class="reveal rounded-2xl border border-line bg-card p-4 sm:p-6">
        <h2 class="display text-xl">{t.spielplan}</h2>
        {d.fussballDeWidget ? (
          // Der fertige Code aus dem fussball.de-Widget-Center. Astro schreibt ihn zur
          // Bauzeit direkt in die Seite, das enthaltene Script wird dadurch normal geladen.
          <div class="mt-5 -mx-2 overflow-x-auto sm:mx-0" set:html={d.fussballDeWidget} />
        ) : (
          <div class="mt-5 rounded-xl border border-dashed border-line bg-paper px-5 py-8 text-center">
            <p class="mx-auto max-w-sm text-sm leading-relaxed text-ink-soft">{t.tabelleEmpty}</p>
            <a href="https://www.fussball.de" rel="noopener" class="mt-4 inline-flex text-sm font-semibold text-club hover:text-club-deep">{t.zufussballde}</a>
          </div>
        )}
      </div>

      <div class="reveal mt-6">
        <h2 class="display text-xl">{t.letzteSpiele}</h2>
        {d.results.length > 0 ? (
          <div class="mt-4 space-y-3">
            {d.results.map((r) => (
              <div class="flex items-center justify-between gap-4 rounded-2xl border border-line bg-card px-5 py-4">
                <div class="min-w-0">
                  <p class="truncate text-sm font-medium">{r.home} <span class="text-ink-soft">{t.gegen}</span> {r.away}</p>
                  <p class="mt-0.5 text-xs text-ink-soft">{r.date}{r.note ? ` · ${r.note}` : ''}</p>
                </div>
                <p class="display shrink-0 text-2xl">{r.score}</p>
              </div>
            ))}
          </div>
        ) : (
          <p class="mt-4 rounded-2xl border border-dashed border-line bg-card px-5 py-6 text-sm text-ink-soft">{t.ergebnisseEmpty}</p>
        )}
      </div>
    </div>
  </div>
</section>

{d.gallery.length > 0 && (
  <section class="border-t border-line bg-card">
    <div class="mx-auto max-w-6xl px-4 py-16 lg:px-6">
      <div class="reveal flex items-end justify-between gap-4">
        <h2 class="display text-2xl md:text-3xl">{t.fotos}</h2>
        <div class="hidden gap-2 md:flex">
          <button data-carousel-prev class="flex h-10 w-10 items-center justify-center rounded-full border border-line bg-paper transition-colors duration-300 hover:border-club hover:text-club" aria-label={t.zurueck}>←</button>
          <button data-carousel-next class="flex h-10 w-10 items-center justify-center rounded-full border border-line bg-paper transition-colors duration-300 hover:border-club hover:text-club" aria-label={t.weiter}>→</button>
        </div>
      </div>
      <div data-carousel class="reveal mt-8 flex snap-x snap-mandatory gap-4 overflow-x-auto scroll-smooth pb-4">
        {d.gallery.map((g) => (
          <figure class="w-[85%] shrink-0 snap-start overflow-hidden rounded-2xl sm:w-[60%] lg:w-[45%]">
            <img src={g.src} alt={g.alt} loading="lazy" class="aspect-[3/2] w-full object-cover" />
            <figcaption class="mt-2 text-xs text-ink-soft">{g.alt}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>
)}

<script>
  const track = document.querySelector('[data-carousel]') as HTMLElement | null;
  const step = () => (track?.querySelector('figure')?.clientWidth ?? 400) + 16;
  document.querySelector('[data-carousel-prev]')?.addEventListener('click', () => track?.scrollBy({ left: -step(), behavior: 'smooth' }));
  document.querySelector('[data-carousel-next]')?.addEventListener('click', () => track?.scrollBy({ left: step(), behavior: 'smooth' }));
</script>
