---
import { defaultLocale, type Locale } from '../../i18n/languages';
import { pageT } from '../../i18n/pages';
import { getLocalized } from '../../i18n/content';

const lang = (Astro.currentLocale ?? defaultLocale) as Locale;
const t = pageT('mannschaftenIndex', lang);
const teams = (await getLocalized('teams', lang)).sort((a, b) => a.data.order - b.data.order);

const prefix = lang === defaultLocale ? '' : `/${lang}`;
---
<section class="mx-auto max-w-6xl px-4 pb-8 pt-16 lg:px-6">
  <h1 class="display text-4xl md:text-5xl">{t.h1}</h1>
  <p class="mt-4 max-w-xl text-base leading-relaxed text-ink-soft">{t.intro}</p>
</section>

<section class="mx-auto max-w-6xl px-4 py-12 lg:px-6">
  <div class="grid gap-6 md:grid-cols-2">
    {teams.map((team) => (
      <a href={`${prefix}/mannschaften/${team.slug}`} class="reveal group relative overflow-hidden rounded-2xl bg-ink">
        <img src={team.data.image} alt={team.data.name} class="absolute inset-0 h-full w-full object-cover opacity-75 transition-transform duration-700 ease-(--ease-club) group-hover:scale-[1.03]" loading="lazy" />
        <div class="absolute inset-0 bg-gradient-to-t from-ink/90 via-ink/30 to-transparent"></div>
        <div class="relative flex min-h-[300px] flex-col justify-end p-7">
          <p class="text-sm font-medium text-white/70">{team.data.league}</p>
          <p class="display mt-1 text-2xl text-white">{team.data.name}</p>
          <p class="mt-3 text-sm text-white/70">{t.trainingLabel}: {team.data.training.join(` ${t.und} `)}</p>
        </div>
      </a>
    ))}
  </div>
</section>
