---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'FC Treptow e.V., dein Fußballclub mitten in Berlin Treptow-Köpenick / Baumschulenweg.' } = Astro.props;

const nav = [
  { href: '/mannschaften', label: 'Mannschaften' },
  { href: '/news', label: 'News' },
  { href: '/vereinschronik', label: 'Verein' },
  { href: '/mitgliedschaft', label: 'Mitgliedschaft' },
  { href: '/kontakt', label: 'Kontakt' },
];
const path = Astro.url.pathname;
---
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/images/crest.jpg" />
    <meta name="description" content={description} />
    <title>{title} | FC Treptow e.V.</title>
  </head>
  <body class="min-h-[100dvh] flex flex-col">
    <header id="site-header" class="sticky top-0 z-40 border-b border-transparent bg-paper/70 backdrop-blur-md transition-[background-color,border-color,box-shadow] duration-500 ease-(--ease-club)">
      <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 lg:px-6">
        <a href="/" class="flex items-center gap-3">
          <img src="/images/crest.jpg" alt="Wappen FC Treptow" class="h-9 w-9 rounded-full object-cover ring-1 ring-line" />
          <span class="display text-sm leading-none">FC Treptow <span class="text-club">e.V.</span></span>
        </a>
        <nav class="hidden items-center gap-6 md:flex">
          {nav.map((item) => (
            <a
              href={item.href}
              class:list={[
                'text-sm font-medium transition-colors duration-300',
                path.startsWith(item.href) ? 'text-club' : 'text-ink-soft hover:text-ink',
              ]}
            >{item.label}</a>
          ))}
          <a href="/mitgliedschaft" data-magnetic class="magnetic group inline-flex items-center gap-2 rounded-full bg-club px-4 py-2 text-sm font-semibold text-white transition-colors duration-300 ease-(--ease-club) hover:bg-club-deep">
            Mitglied werden
            <span class="flex h-5 w-5 items-center justify-center rounded-full bg-white/15 transition-transform duration-300 ease-(--ease-club) group-hover:translate-x-0.5">→</span>
          </a>
        </nav>
        <button id="menu-btn" class="flex h-10 w-10 flex-col items-center justify-center gap-1.5 md:hidden" aria-label="Menü öffnen" aria-expanded="false">
          <span class="menu-line block h-0.5 w-6 bg-ink transition-transform duration-300 ease-(--ease-club)"></span>
          <span class="menu-line block h-0.5 w-6 bg-ink transition-transform duration-300 ease-(--ease-club)"></span>
        </button>
      </div>
      <div id="mobile-menu" class="hidden border-t border-line bg-paper px-4 py-4 md:hidden">
        <nav class="flex flex-col gap-3">
          {nav.map((item) => (
            <a href={item.href} class="py-1 text-base font-medium text-ink">{item.label}</a>
          ))}
          <a href="/mitgliedschaft" class="mt-2 inline-flex w-max items-center rounded-full bg-club px-5 py-2.5 text-sm font-semibold text-white">Mitglied werden</a>
        </nav>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="mt-24 bg-ink text-white">
      <div class="mx-auto grid max-w-6xl gap-10 px-4 py-16 md:grid-cols-4 lg:px-6">
        <div class="md:col-span-2">
          <div class="flex items-center gap-3">
            <img src="/images/crest.jpg" alt="" class="h-10 w-10 rounded-full object-cover" />
            <p class="display text-lg">FC Treptow e.V.</p>
          </div>
          <p class="mt-4 max-w-sm text-sm leading-relaxed text-white/70">
            Dein Fußballclub mitten in Berlin, seit 1925 im Kiez verwurzelt.
            Willi-Sänger-Sportanlage, Köpenicker Landstraße 186, 12437 Berlin.
          </p>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-white/50">Verein</p>
          <ul class="mt-4 space-y-2 text-sm">
            <li><a href="/vereinschronik" class="text-white/80 hover:text-white">Vereinschronik</a></li>
            <li><a href="/sponsoren" class="text-white/80 hover:text-white">Sponsoren</a></li>
            <li><a href="/downloads" class="text-white/80 hover:text-white">Downloads</a></li>
            <li><a href="/in-gedenken" class="text-white/80 hover:text-white">In Gedenken</a></li>
          </ul>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-white/50">Kontakt</p>
          <ul class="mt-4 space-y-2 text-sm text-white/80">
            <li><a href="mailto:kontakt@fc-treptow.de" class="hover:text-white">kontakt@fc-treptow.de</a></li>
            <li><a href="/kontakt" class="hover:text-white">Anfahrt und Kontakt</a></li>
            <li><a href="https://www.instagram.com" rel="noopener" class="hover:text-white">Instagram</a></li>
          </ul>
        </div>
      </div>
      <div class="border-t border-white/10">
        <div class="mx-auto flex max-w-6xl flex-col gap-2 px-4 py-6 text-xs text-white/50 sm:flex-row sm:items-center sm:justify-between lg:px-6">
          <p>© {new Date().getFullYear()} FC Treptow e.V.</p>
          <div class="flex gap-4">
            <a href="/impressum" class="hover:text-white">Impressum</a>
            <a href="/datenschutz" class="hover:text-white">Datenschutz</a>
          </div>
        </div>
      </div>
    </footer>

    <script>
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // Mobile-Menü mit Hamburger-Morph
      const btn = document.getElementById('menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => {
        const open = menu?.classList.toggle('hidden') === false;
        btn.setAttribute('aria-expanded', String(open));
        const lines = btn.querySelectorAll('.menu-line');
        lines[0]?.classList.toggle('rotate-45', open);
        lines[0]?.classList.toggle('translate-y-1', open);
        lines[1]?.classList.toggle('-rotate-45', open);
        lines[1]?.classList.toggle('-translate-y-1', open);
      });

      // Header setzt sich erst ab, wenn Inhalt darunter liegt
      const header = document.getElementById('site-header');
      const sentinel = document.createElement('div');
      sentinel.setAttribute('aria-hidden', 'true');
      document.body.prepend(sentinel);
      new IntersectionObserver(
        ([e]) => {
          const stuck = !e.isIntersecting;
          header?.classList.toggle('border-line/80', stuck);
          header?.classList.toggle('bg-paper/85', stuck);
          header?.classList.toggle('shadow-[0_10px_30px_-24px_rgba(20,23,31,0.6)]', stuck);
        },
        { rootMargin: '0px' }
      ).observe(sentinel);

      // Scroll-Reveal, einmalig pro Element
      const observer = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('is-visible');
              observer.unobserve(e.target);
            }
          }
        },
        { threshold: 0.15, rootMargin: '0px 0px -8% 0px' }
      );
      document.querySelectorAll('.reveal, .stagger').forEach((el) => observer.observe(el));

      // Magnetische Buttons: Transform direkt, ohne Layout-Properties
      if (!reduced && window.matchMedia('(pointer: fine)').matches) {
        document.querySelectorAll('[data-magnetic]').forEach((el) => {
          const strength = 0.28;
          el.addEventListener('pointermove', (ev) => {
            const r = el.getBoundingClientRect();
            const x = (ev.clientX - (r.left + r.width / 2)) * strength;
            const y = (ev.clientY - (r.top + r.height / 2)) * strength;
            el.classList.add('is-pulling');
            el.style.transform = `translate3d(${x}px, ${y}px, 0)`;
          });
          el.addEventListener('pointerleave', () => {
            el.classList.remove('is-pulling');
            el.style.transform = 'translate3d(0, 0, 0)';
          });
          el.addEventListener('pointerdown', () => {
            el.style.transform += ' scale(0.97)';
          });
          el.addEventListener('pointerup', () => {
            el.classList.remove('is-pulling');
            el.style.transform = 'translate3d(0, 0, 0)';
          });
        });
      }
    </script>
  </body>
</html>
