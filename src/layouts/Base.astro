---
import '../styles/global.css';
import { locales, defaultLocale, languageNames, isRtl, type Locale } from '../i18n/languages';
import { useTranslations } from '../i18n/ui';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'FC Treptow e.V., dein Fußballclub mitten in Berlin Treptow-Köpenick / Baumschulenweg.' } = Astro.props;

const lang = (Astro.currentLocale ?? defaultLocale) as Locale;
const t = useTranslations(lang);
const dir = isRtl(lang) ? 'rtl' : 'ltr';
const homeHref = lang === defaultLocale ? '/' : `/${lang}`;

const nav = [
  { href: '/mannschaften', label: t.nav.teams },
  { href: '/news', label: t.nav.news },
  { href: '/vereinschronik', label: t.nav.verein },
  { href: '/mitgliedschaft', label: t.nav.mitgliedschaft },
  { href: '/kontakt', label: t.nav.kontakt },
];
const path = Astro.url.pathname;

// Der Sprachumschalter führt aktuell zur jeweils übersetzten Startseite: nur sie existiert bislang je Sprache.
// Alle übrigen Seiten (Mannschaften, News, Verein ...) bleiben deutschsprachig, bis sie ebenfalls übersetzt sind.
function langHref(locale: Locale) {
  return locale === defaultLocale ? '/' : `/${locale}`;
}
---
<html lang={lang} dir={dir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/images/crest.jpg" />
    <meta name="description" content={description} />
    <title>{title} | FC Treptow e.V.</title>
    {locales.map((locale) => (
      <link rel="alternate" hreflang={locale} href={langHref(locale)} />
    ))}
  </head>
  <body class="min-h-[100dvh] flex flex-col">
    <header id="site-header" class="sticky top-0 z-40 border-b border-transparent bg-paper/70 backdrop-blur-md transition-[background-color,border-color,box-shadow] duration-500 ease-(--ease-club)">
      <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 lg:px-6">
        <a href={homeHref} class="flex items-center gap-3">
          <img src="/images/crest.jpg" alt="Wappen FC Treptow" class="h-9 w-9 rounded-full object-cover ring-1 ring-line" />
          <span class="display text-sm leading-none">FC Treptow <span class="text-club">e.V.</span></span>
        </a>
        <nav class="hidden items-center gap-4 lg:flex xl:gap-6">
          {nav.map((item) => (
            <a
              href={item.href}
              class:list={[
                'text-sm font-medium transition-colors duration-300',
                path.startsWith(item.href) ? 'text-club' : 'text-ink-soft hover:text-ink',
              ]}
            >{item.label}</a>
          ))}
          <div class="relative" data-lang-menu>
            <button type="button" data-lang-toggle aria-haspopup="true" aria-expanded="false" class="flex items-center gap-1.5 rounded-full border border-line px-3 py-1.5 text-xs font-semibold uppercase tracking-wide text-ink-soft transition-colors duration-300 hover:border-club hover:text-club">
              {lang}
              <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M2 3.5L5 6.5L8 3.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <div data-lang-dropdown class="invisible absolute end-0 top-full z-50 mt-2 w-40 origin-top-right scale-95 rounded-2xl border border-line bg-card p-1.5 opacity-0 shadow-[0_16px_40px_-16px_rgba(20,23,31,0.35)] transition-all duration-200 ease-(--ease-club)">
              {locales.map((locale) => (
                <a
                  href={langHref(locale)}
                  class:list={[
                    'block rounded-xl px-3 py-2 text-sm transition-colors duration-200',
                    locale === lang ? 'bg-club/10 font-semibold text-club' : 'text-ink hover:bg-paper',
                  ]}
                >{languageNames[locale]}</a>
              ))}
            </div>
          </div>
          <a href="/mitgliedschaft" data-magnetic class="magnetic group inline-flex items-center gap-2 rounded-full bg-club px-4 py-2 text-sm font-semibold text-white transition-colors duration-300 ease-(--ease-club) hover:bg-club-deep">
            {t.joinCta}
            <span class="flex h-5 w-5 items-center justify-center rounded-full bg-white/15 transition-transform duration-300 ease-(--ease-club) group-hover:translate-x-0.5 rtl:rotate-180">→</span>
          </a>
        </nav>
        <button id="menu-btn" class="flex h-10 w-10 flex-col items-center justify-center gap-1.5 lg:hidden" aria-label="Menü öffnen" aria-expanded="false">
          <span class="menu-line block h-0.5 w-6 bg-ink transition-transform duration-300 ease-(--ease-club)"></span>
          <span class="menu-line block h-0.5 w-6 bg-ink transition-transform duration-300 ease-(--ease-club)"></span>
        </button>
      </div>
      <div id="mobile-menu" class="hidden border-t border-line bg-paper px-4 py-4 lg:hidden">
        <nav class="flex flex-col gap-3">
          {nav.map((item) => (
            <a href={item.href} class="py-1 text-base font-medium text-ink">{item.label}</a>
          ))}
          <a href="/mitgliedschaft" class="mt-2 inline-flex w-max items-center rounded-full bg-club px-5 py-2.5 text-sm font-semibold text-white">{t.joinCta}</a>
          <div class="mt-3 border-t border-line pt-3">
            <p class="text-xs font-semibold uppercase tracking-widest text-ink-soft">{t.langSwitcher}</p>
            <div class="mt-2 flex flex-wrap gap-2">
              {locales.map((locale) => (
                <a
                  href={langHref(locale)}
                  class:list={[
                    'rounded-full border px-3 py-1.5 text-xs font-semibold uppercase',
                    locale === lang ? 'border-club bg-club/10 text-club' : 'border-line text-ink-soft',
                  ]}
                >{locale}</a>
              ))}
            </div>
          </div>
        </nav>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="mt-24 bg-ink text-white">
      <div class="mx-auto grid max-w-6xl gap-10 px-4 py-16 md:grid-cols-4 lg:px-6">
        <div class="md:col-span-2">
          <div class="flex items-center gap-3">
            <img src="/images/crest.jpg" alt="" class="h-10 w-10 rounded-full object-cover" />
            <p class="display text-lg">FC Treptow e.V.</p>
          </div>
          <p class="mt-4 max-w-sm text-sm leading-relaxed text-white/70">
            {t.footerTagline}
            <br />Willi-Sänger-Sportanlage, Köpenicker Landstraße 186, 12437 Berlin.
          </p>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-white/50">{t.footerVereinHeading}</p>
          <ul class="mt-4 space-y-2 text-sm">
            <li><a href="/vereinschronik" class="text-white/80 hover:text-white">{t.footerChronik}</a></li>
            <li><a href="/sponsoren" class="text-white/80 hover:text-white">{t.footerSponsoren}</a></li>
            <li><a href="/downloads" class="text-white/80 hover:text-white">{t.footerDownloads}</a></li>
            <li><a href="/in-gedenken" class="text-white/80 hover:text-white">{t.footerGedenken}</a></li>
          </ul>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-white/50">{t.footerKontaktHeading}</p>
          <ul class="mt-4 space-y-2 text-sm text-white/80">
            <li><a href="mailto:kontakt@fc-treptow.de" class="hover:text-white">kontakt@fc-treptow.de</a></li>
            <li><a href="/kontakt" class="hover:text-white">{t.footerAnfahrt}</a></li>
            <li><a href="https://www.instagram.com/fctreptow" rel="noopener" class="hover:text-white">Instagram</a></li>
            <li><a href="https://www.facebook.com/fctreptow" rel="noopener" class="hover:text-white">Facebook</a></li>
            <li><a href="https://www.tiktok.com/@fctreptow" rel="noopener" class="hover:text-white">TikTok</a></li>
          </ul>
        </div>
      </div>
      <div class="border-t border-white/10">
        <div class="mx-auto flex max-w-6xl flex-col gap-2 px-4 py-6 text-xs text-white/50 sm:flex-row sm:items-center sm:justify-between lg:px-6">
          <p>© {new Date().getFullYear()} FC Treptow e.V.</p>
          <div class="flex gap-4">
            <a href="/impressum" class="hover:text-white">{t.footerImpressum}</a>
            <a href="/datenschutz" class="hover:text-white">{t.footerDatenschutz}</a>
          </div>
        </div>
      </div>
    </footer>

    <script>
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // Mobile-Menü mit Hamburger-Morph
      const btn = document.getElementById('menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => {
        const open = menu?.classList.toggle('hidden') === false;
        btn.setAttribute('aria-expanded', String(open));
        const lines = btn.querySelectorAll('.menu-line');
        lines[0]?.classList.toggle('rotate-45', open);
        lines[0]?.classList.toggle('translate-y-1', open);
        lines[1]?.classList.toggle('-rotate-45', open);
        lines[1]?.classList.toggle('-translate-y-1', open);
      });

      // Sprachmenü (Desktop)
      const langMenu = document.querySelector('[data-lang-menu]');
      const langToggle = langMenu?.querySelector('[data-lang-toggle]');
      const langDropdown = langMenu?.querySelector('[data-lang-dropdown]');
      const closeLangMenu = () => {
        langDropdown?.classList.add('invisible', 'opacity-0', 'scale-95');
        langToggle?.setAttribute('aria-expanded', 'false');
      };
      langToggle?.addEventListener('click', (e) => {
        e.stopPropagation();
        const isOpen = !langDropdown?.classList.contains('invisible');
        if (isOpen) {
          closeLangMenu();
        } else {
          langDropdown?.classList.remove('invisible', 'opacity-0', 'scale-95');
          langToggle.setAttribute('aria-expanded', 'true');
        }
      });
      document.addEventListener('click', (e) => {
        if (langMenu && !langMenu.contains(e.target as Node)) closeLangMenu();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeLangMenu();
      });

      // Header setzt sich erst ab, wenn Inhalt darunter liegt
      const header = document.getElementById('site-header');
      const sentinel = document.createElement('div');
      sentinel.setAttribute('aria-hidden', 'true');
      document.body.prepend(sentinel);
      new IntersectionObserver(
        ([e]) => {
          const stuck = !e.isIntersecting;
          header?.classList.toggle('border-line/80', stuck);
          header?.classList.toggle('bg-paper/85', stuck);
          header?.classList.toggle('shadow-[0_10px_30px_-24px_rgba(20,23,31,0.6)]', stuck);
        },
        { rootMargin: '0px' }
      ).observe(sentinel);

      // Scroll-Reveal, einmalig pro Element
      const observer = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('is-visible');
              observer.unobserve(e.target);
            }
          }
        },
        { threshold: 0.15, rootMargin: '0px 0px -8% 0px' }
      );
      document.querySelectorAll('.reveal, .stagger').forEach((el) => observer.observe(el));

      // Magnetische Buttons: Transform direkt, ohne Layout-Properties
      if (!reduced && window.matchMedia('(pointer: fine)').matches) {
        document.querySelectorAll('[data-magnetic]').forEach((el) => {
          const strength = 0.28;
          el.addEventListener('pointermove', (ev) => {
            const r = el.getBoundingClientRect();
            const x = (ev.clientX - (r.left + r.width / 2)) * strength;
            const y = (ev.clientY - (r.top + r.height / 2)) * strength;
            el.classList.add('is-pulling');
            el.style.transform = `translate3d(${x}px, ${y}px, 0)`;
          });
          el.addEventListener('pointerleave', () => {
            el.classList.remove('is-pulling');
            el.style.transform = 'translate3d(0, 0, 0)';
          });
          el.addEventListener('pointerdown', () => {
            el.style.transform += ' scale(0.97)';
          });
          el.addEventListener('pointerup', () => {
            el.classList.remove('is-pulling');
            el.style.transform = 'translate3d(0, 0, 0)';
          });
        });
      }
    </script>
  </body>
</html>
