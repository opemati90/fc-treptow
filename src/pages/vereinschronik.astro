import Sections from '../components/sections/VereinschronikSections.astro';
import { pageT } from '../i18n/pages';
import { defaultLocale } from '../i18n/languages';

const lang = Astro.currentLocale ?? defaultLocale;
const t = pageT('vereinschronik', lang as any);
---
<Base title={t.metaTitle} description={t.metaDesc}>
  <Sections />
</Base>
